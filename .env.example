# Exemplo de variáveis de ambiente (NÃO coloque segredos aqui)
# Copie para .env.local e preencha com seus valores.

# --- Next.js / Supabase (App) ---
# URL do projeto no Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública do Supabase (Settings → API Keys)
# Novo formato: sb_publishable_... (recomendado)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Fallback legado (se seu projeto ainda usa JWT anon key):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta do Supabase (APENAS server-side).
# Novo formato: sb_secret_... (recomendado)
# Nunca exponha no client e nunca comite.
SUPABASE_SECRET_KEY=
# Fallback legado (se seu projeto ainda usa JWT service_role key):
# SUPABASE_SERVICE_ROLE_KEY=

# --- Dev-only ---
# Habilita rotas internas de teste de IA em desenvolvimento.
ALLOW_AI_TEST_ROUTE=false

# Habilita rotas internas de mock de UI em desenvolvimento.
ALLOW_UI_MOCKS_ROUTE=false

# --- Installer (ops only) ---
# Se INSTALLER_ENABLED nao estiver definido, o instalador fica liberado ate a primeira instalacao.
# Defina como false para desativar o instalador (recomendado apos o setup).
INSTALLER_ENABLED=false

# Token opcional para proteger o instalador (se definido, passa a ser obrigatorio).
INSTALLER_TOKEN=

# --- WhatsApp / Evolution API ---
# Base URL da sua Evolution API (sem barra final)
EVOLUTION_API_URL=
# API key da Evolution
EVOLUTION_API_KEY=
# Nome da instance conectada na Evolution
EVOLUTION_INSTANCE=

# Webhook de entrada (Evolution -> CRM)
# Base publica para o CRM montar a URL de webhook automaticamente
# Ex: https://seucrm.com.br
EVOLUTION_WEBHOOK_PUBLIC_BASE_URL=
# Token opcional para validar chamadas no endpoint /api/webhooks/evolution
EVOLUTION_WEBHOOK_TOKEN=
# Fonte inbound no CRM (integration_inbound_sources.id)
EVOLUTION_WEBHOOK_SOURCE_ID=
# Secret da fonte inbound no CRM
EVOLUTION_WEBHOOK_SOURCE_SECRET=
